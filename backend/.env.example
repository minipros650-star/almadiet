# ── Database (PostgreSQL Cloud) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/almadiet

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ── Google Gemini API (optional, stubbed by default) ──────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── CORS (comma-separated origins, or * for all) ─────────────
ALLOWED_ORIGINS=*
